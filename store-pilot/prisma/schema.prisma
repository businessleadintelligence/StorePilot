generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum SubscriptionPlan {
  starter
  growth
  scale
  agency
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

enum UsageMetric {
  products
  orders
  ai_requests
  reports_generated
}

enum AIAgentId {
  product_intelligence
  inventory_intelligence
  bundle_discovery
  executive_summary
  seo_audit
  store_audit
  offer_intelligence
  trend_intelligence
  pricing_intelligence
  growth_intelligence
  executive_coo
  platform_template
}

enum AIExecutionStatus {
  pending
  running
  retry
  succeeded
  failed
  cached
  skipped
}

enum AIValidationStatus {
  valid
  invalid
  retried
  failed_after_retry
}

enum AIRecommendationStatus {
  open
  viewed
  implemented
  dismissed
  verified
  closed
}

enum AIMemoryScope {
  recommendation
  merchant_action
  dismissal
  preference
}

enum UserRole {
  owner
  member
}

enum ProductStatus {
  active
  archived
  draft
}

enum JobType {
  onboarding_bootstrap
  bootstrap_products
  bootstrap_inventory
  orders_historical
  orders_incremental
  connector_sync
  metrics_recompute
  recommendations_generate
  executive_brief_generate
  founder_maintenance
  knowledge_ingest
  knowledge_fact_refresh
  knowledge_graph_build
  knowledge_graph_incremental
  learning_bootstrap
  historical_intelligence
  quick_wins_generate
  executive_decision_generate
  executive_coo_generate
  root_cause_generate
  prediction_generate
  experiment_generate
  merchant_intelligence_refresh
}

enum JobStatus {
  queued
  claimed
  running
  retrying
  completed
  failed
  dead_letter
  cancelled
}

enum WorkerInstanceStatus {
  active
  draining
  stopped
}

enum JobPriority {
  critical
  high
  normal
  low
}

enum OnboardingStatus {
  not_started
  queued
  running
  completed
  failed
}

enum OnboardingPhaseStatus {
  not_started
  queued
  running
  completed
  failed
  blocked
  skipped
}

enum JobEventType {
  claimed
  completed
  failed
  retried
  dead_lettered
  cancelled
  progress
}

enum JobEventActor {
  system
  worker
  merchant
  founder
  cron
}

model Store {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopifyDomain        String             @unique @db.VarChar(255)
  shopifyId            String             @unique @db.VarChar(100)
  accessToken          String
  storeName            String             @db.VarChar(255)
  currency             String             @default("USD") @db.VarChar(10)
  timezone             String             @default("UTC") @db.VarChar(100)
  subscriptionPlan     SubscriptionPlan   @default(starter)
  subscriptionStatus   SubscriptionStatus @default(trialing)
  trialEndsAt          DateTime?          @db.Timestamptz
  ga4PropertyId        String?            @db.VarChar(100)
  ga4RefreshToken      String?
  ga4ConnectedAt       DateTime?          @db.Timestamptz
  briefingTime         String             @default("08:00") @db.VarChar(5)
  briefingTimezone     String             @default("UTC") @db.VarChar(100)
  active               Boolean            @default(true)
  lastAuthenticatedAt        DateTime?          @db.Timestamptz
  firstTrialStartedAt        DateTime?          @db.Timestamptz
  historicalImportDone         Boolean            @default(false)
  historicalOrdersImportDone   Boolean            @default(false)
  ordersSyncCursor             String?            @db.Text
  lastOrdersSyncAt             DateTime?          @db.Timestamptz
  lastInventorySyncAt  DateTime?          @db.Timestamptz
  lastRefundsSyncAt    DateTime?          @db.Timestamptz
  lastProductsSyncAt   DateTime?          @db.Timestamptz
  lastGa4SyncAt        DateTime?          @db.Timestamptz
  createdAt            DateTime           @default(now()) @db.Timestamptz
  updatedAt            DateTime           @updatedAt @db.Timestamptz
  users                User[]
  products             Product[]
  webhookEvents        WebhookEvent[]
  orders               Order[]
  orderLineItems       OrderLineItem[]
  syncJobs             SyncJob[]
  jobEvents            JobEvent[]
  storeOnboarding      StoreOnboarding?
  subscription         Subscription?
  usageRecords         UsageRecord[]
  googleIntegration    GoogleIntegration?
  microsoftClarityIntegration MicrosoftClarityIntegration?
  customerDataExports  CustomerDataExport[]
  aiAgentRuns          AiAgentRun[]
  aiAgentResults       AiAgentResult[]
  aiRecommendations    AiRecommendation[]
  aiMemoryRecords      AiMemoryRecord[]
  aiResultCacheEntries AiResultCacheEntry[]
  aiCostLedger         AiCostLedger[]
  aiMerchantBudget     AiMerchantBudget?
  evidenceRecords      Evidence[]
  evidenceSources      EvidenceSource[]
  evidenceObservations EvidenceObservation[]
  evidenceHistory      EvidenceHistory[]
  evidenceRelationships EvidenceRelationship[]
  knowledgeSyncCheckpoint KnowledgeSyncCheckpoint?
  knowledgeReadiness   KnowledgeReadiness?
  knowledgeGraphNodes  KnowledgeGraphNode[]
  knowledgeGraphEdges  KnowledgeGraphEdge[]
  knowledgeGraphRelationships KnowledgeGraphRelationship[]
  knowledgeGraphVersions KnowledgeGraphVersion[]
  knowledgeGraphSnapshots KnowledgeGraphSnapshot[]
  knowledgeGraphMetadata KnowledgeGraphMetadata?
  knowledgeGraphIntegrity KnowledgeGraphIntegrity?
  knowledgeGraphStatistics KnowledgeGraphStatistics?
  knowledgeGraphSearchIndex KnowledgeGraphSearchIndex[]
  knowledgeGraphBuildCheckpoint KnowledgeGraphBuildCheckpoint?
  storeLearningProfile        StoreLearningProfile?
  learningReadiness           LearningReadiness?
  learningVelocities          LearningVelocity[]
  learningEta                 LearningEta?
  learningPriorities          LearningPriority[]
  historicalMemory            HistoricalMemory?
  historicalSnapshots         HistoricalSnapshot[]
  patternSeeds                PatternSeed[]
  confidenceSeeds             ConfidenceSeed[]
  merchantBaselines           MerchantBaseline[]
  businessDnaVersions         BusinessDnaVersion[]
  quickWins                   QuickWin[]
  quickWinSummary             QuickWinSummary?
  executiveDecisions          ExecutiveDecision[]
  decisionTasks               DecisionTask[]
  decisionHistory             DecisionHistory[]
  executiveBriefings          ExecutiveBriefing[]
  dailyOperatingPlans         DailyOperatingPlan[]
  operationalReadiness        OperationalReadiness?
  decisionScores              DecisionScore[]
  businessContextSnapshots    BusinessContextSnapshot[]
  rootCauses                  RootCause[]
  causalChains                CausalChain[]
  causalTimelines             CausalTimeline[]
  signalCorrelations          SignalCorrelation[]
  causeConfidences            CauseConfidence[]
  impactAssessments           ImpactAssessment[]
  causalGraphEdges            CausalGraphEdge[]
  rootCauseHistory            RootCauseHistory[]
  predictions                 Prediction[]
  predictionHistory           PredictionHistory[]
  predictionConfidences       PredictionConfidence[]
  forecastModels              ForecastModel[]
  forecastSnapshots           ForecastSnapshot[]
  preventionActions           PreventionAction[]
  riskAssessments             RiskAssessment[]
  forecastAccuracy            ForecastAccuracy[]
  businessStability           BusinessStability?
  experiments                 Experiment[]
  experimentTemplates         ExperimentTemplate[]
  experimentOpportunities     ExperimentOpportunity[]
  experimentRecommendations   ExperimentRecommendation[]
  experimentBaselines         ExperimentBaseline[]
  experimentVariants          ExperimentVariant[]
  experimentObservations      ExperimentObservation[]
  experimentResults           ExperimentResult[]
  experimentWinners           ExperimentWinner[]
  experimentHistory           ExperimentHistory[]
  experimentLearning          ExperimentLearning[]
  experimentConfidences       ExperimentConfidence[]
  decisionJournal             DecisionJournal[]
  merchantDecisions           MerchantDecision[]
  merchantFeedback            MerchantFeedback[]
  adaptiveMemory              AdaptiveMemory[]
  recommendationOutcomes      RecommendationOutcome[]
  predictionAccuracyRecords   PredictionAccuracyRecord[]
  predictionValidations       PredictionValidation[]
  rootCauseValidations        RootCauseValidation[]
  merchantPreferences         MerchantPreference[]
  merchantBehaviorProfiles    MerchantBehaviorProfile[]
  personalizationProfiles     PersonalizationProfile[]
  adaptiveConfidences         AdaptiveConfidence[]
  adaptiveScore               AdaptiveScore?
  decisionTimelines           DecisionTimeline[]
  merchantTimeline            MerchantTimeline[]
  businessMemoryVersions      BusinessMemoryVersion[]
  learningHistory             LearningHistory[]
  learningSnapshots           LearningSnapshot[]
  learningAttributions        LearningAttribution[]

  @@index([active, subscriptionPlan])
  @@index([briefingTime])
  @@map("stores")
}

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId     String    @db.Uuid
  email       String    @db.VarChar(320)
  name        String?   @db.VarChar(255)
  role        UserRole  @default(owner)
  lastLoginAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([email, storeId], map: "users_email_store_idx")
  @@index([storeId], map: "users_store_id_idx")
  @@map("users")
}

/// @privacy merchant-pii — OAuth session; firstName/lastName not persisted (alias-only)
/// @secrets accessToken, refreshToken (encrypted spenc:v1:)
/// @retention until expiry; purged by expired-sessions cron
model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Product {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId                String        @db.Uuid
  shopifyProductId       String        @db.VarChar(100)
  shopifyVariantId       String        @db.VarChar(100)
  shopifyInventoryItemId String?       @db.VarChar(100)
  title                  String        @db.VarChar(500)
  sku                    String?       @db.VarChar(255)
  status                 ProductStatus @default(active)
  price                  Decimal?      @db.Decimal(12, 2)
  inventoryQuantity      Int?
  inventoryTracked       Boolean       @default(true)
  shopifyProductUpdatedAt DateTime?    @db.Timestamptz
  createdAt              DateTime      @default(now()) @db.Timestamptz
  updatedAt              DateTime      @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([storeId, shopifyVariantId], map: "products_store_variant_unique")
  @@index([storeId], map: "products_store_id_idx")
  @@index([storeId, shopifyProductId], map: "products_store_product_idx")
  @@index([storeId, status], map: "products_status_idx")
  @@index([storeId, inventoryTracked], map: "products_inventory_tracked_idx")
  @@index([storeId, shopifyInventoryItemId], map: "products_inventory_item_idx")
  @@map("products")
}

model WebhookEvent {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId               String    @db.Uuid
  shopifyWebhookId      String    @unique(map: "webhook_events_shopify_webhook_id_unique") @db.VarChar(255)
  shop                  String    @db.VarChar(255)
  topic                 String    @db.VarChar(100)
  processedSuccessfully Boolean   @default(true)
  processedAt           DateTime? @db.Timestamptz
  processingOwner       String?   @db.VarChar(100)
  processingExpiresAt   DateTime? @db.Timestamptz
  createdAt             DateTime  @default(now()) @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([storeId], map: "webhook_events_store_id_idx")
  @@index([processedSuccessfully, createdAt], map: "webhook_events_processed_created_idx")
  @@index([processingExpiresAt], map: "webhook_events_processing_expires_idx")
  @@map("webhook_events")
}

/// @privacy operational-metrics — order-level commerce facts without shopper identity
/// @retention durable until store uninstall or customer redact
model Order {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId                String    @db.Uuid
  shopifyOrderId         String    @db.VarChar(100)
  orderName              String    @db.VarChar(50)
  privacyRedacted        Boolean   @default(false)
  shopifyCreatedAt       DateTime  @db.Timestamptz
  shopifyUpdatedAt       DateTime  @db.Timestamptz
  processedAt            DateTime  @db.Timestamptz
  cancelledAt            DateTime? @db.Timestamptz
  metricDate             DateTime  @db.Date
  displayFinancialStatus String?   @db.VarChar(50)
  currencyCode           String    @db.VarChar(10)
  subtotalAmount         Decimal   @db.Decimal(14, 2)
  totalTaxAmount         Decimal   @db.Decimal(14, 2)
  totalDiscountAmount    Decimal   @db.Decimal(14, 2)
  totalPriceAmount       Decimal   @db.Decimal(14, 2)
  totalRefundedAmount    Decimal   @default(0) @db.Decimal(14, 2)
  isTest                 Boolean   @default(false)
  isPaid                 Boolean   @default(false)
  createdAt              DateTime  @default(now()) @db.Timestamptz
  updatedAt              DateTime  @updatedAt @db.Timestamptz

  store     Store           @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  lineItems OrderLineItem[]

  @@unique([storeId, shopifyOrderId], map: "orders_store_order_unique")
  @@index([storeId], map: "orders_store_id_idx")
  @@index([storeId, metricDate], map: "orders_store_metric_date_idx")
  @@index([storeId, shopifyUpdatedAt], map: "orders_store_updated_at_idx")
  @@index([storeId, isPaid, metricDate], map: "orders_store_paid_metric_date_idx")
  @@index([storeId, privacyRedacted], map: "orders_store_privacy_redacted_idx")
  @@map("orders")
}

model OrderLineItem {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId             String   @db.Uuid
  orderId             String   @db.Uuid
  privacyRedacted     Boolean  @default(false)
  shopifyLineItemId   String   @db.VarChar(100)
  shopifyOrderId      String   @db.VarChar(100)
  shopifyProductId    String?  @db.VarChar(100)
  shopifyVariantId    String?  @db.VarChar(100)
  sku                 String?  @db.VarChar(255)
  title               String   @db.VarChar(500)
  quantity            Int
  originalUnitPrice   Decimal  @db.Decimal(12, 2)
  discountedUnitPrice Decimal  @db.Decimal(12, 2)
  isGiftCard          Boolean  @default(false)
  createdAt           DateTime @default(now()) @db.Timestamptz
  updatedAt           DateTime @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([storeId, shopifyLineItemId], map: "order_line_items_store_line_unique")
  @@index([storeId], map: "order_line_items_store_id_idx")
  @@index([orderId], map: "order_line_items_order_id_idx")
  @@index([storeId, shopifyVariantId], map: "order_line_items_store_variant_idx")
  @@map("order_line_items")
}

model SyncJob {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId        String      @db.Uuid
  jobType        JobType
  status         JobStatus   @default(queued)
  priority       JobPriority @default(normal)
  payload        Json        @default("{}") @db.JsonB
  cursorJson     Json?       @db.JsonB
  progressJson   Json?       @db.JsonB
  attempts       Int         @default(0)
  maxAttempts    Int
  availableAt    DateTime    @default(now()) @db.Timestamptz
  startedAt      DateTime?   @db.Timestamptz
  completedAt    DateTime?   @db.Timestamptz
  failedAt       DateTime?   @db.Timestamptz
  deadLetterAt   DateTime?   @db.Timestamptz
  cancelledAt    DateTime?   @db.Timestamptz
  errorCode      String?     @db.VarChar(100)
  errorMessage   String?     @db.Text
  idempotencyKey String      @unique @db.VarChar(255)
  lockedBy       String?     @db.VarChar(100)
  lockedAt       DateTime?   @db.Timestamptz
  lockExpiresAt  DateTime?   @db.Timestamptz
  heartbeatAt    DateTime?   @db.Timestamptz
  workerGeneration Int       @default(0)
  durationMs     Int?
  createdAt      DateTime    @default(now()) @db.Timestamptz
  updatedAt      DateTime    @updatedAt @db.Timestamptz

  store                          Store             @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  jobEvents                      JobEvent[]
  onboardingAsCurrentJob         StoreOnboarding[] @relation("OnboardingCurrentJob")
  onboardingAsProductSyncJob     StoreOnboarding[] @relation("OnboardingProductSyncJob")
  onboardingAsInventorySyncJob   StoreOnboarding[] @relation("OnboardingInventorySyncJob")
  onboardingAsOrdersSyncJob      StoreOnboarding[] @relation("OnboardingOrdersSyncJob")

  @@index([storeId], map: "sync_jobs_store_id_idx")
  @@index([status, availableAt, priority], map: "sync_jobs_claim_idx")
  @@index([storeId, jobType, status], map: "sync_jobs_store_type_status_idx")
  @@index([status, deadLetterAt], map: "sync_jobs_dead_letter_idx")
  @@index([status, lockExpiresAt], map: "sync_jobs_stale_lock_idx")
  @@index([createdAt], map: "sync_jobs_created_at_idx")
  @@map("sync_jobs")
}

model WorkerInstance {
  id              String               @id @db.VarChar(100)
  hostname        String?              @db.VarChar(255)
  pid             Int?
  status          WorkerInstanceStatus @default(active)
  startedAt       DateTime             @default(now()) @db.Timestamptz
  lastHeartbeatAt DateTime             @default(now()) @db.Timestamptz
  stoppedAt       DateTime?            @db.Timestamptz
  jobsProcessed   Int                  @default(0)
  jobsFailed      Int                  @default(0)
  currentJobId    String?              @db.Uuid
  version         String?              @db.VarChar(50)
  metadata        Json                 @default("{}") @db.JsonB

  @@index([status, lastHeartbeatAt], map: "worker_instances_heartbeat_idx")
  @@map("worker_instances")
}

model StoreOnboarding {
  id                       String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId                  String                @unique @db.Uuid
  status                   OnboardingStatus      @default(not_started)
  onboardingRunId          String                @db.Uuid
  currentJobId             String?               @db.Uuid
  productSyncStatus        OnboardingPhaseStatus @default(not_started)
  productSyncJobId         String?               @db.Uuid
  productSyncCompletedAt   DateTime?             @db.Timestamptz
  inventorySyncStatus      OnboardingPhaseStatus @default(not_started)
  inventorySyncJobId     String?               @db.Uuid
  inventorySyncCompletedAt DateTime?             @db.Timestamptz
  ordersSyncStatus         OnboardingPhaseStatus @default(not_started)
  ordersSyncJobId          String?               @db.Uuid
  ordersSyncCompletedAt    DateTime?             @db.Timestamptz
  ownershipRepairPending   Boolean               @default(false)
  blockedReason            String?               @db.VarChar(100)
  blockedMessage           String?               @db.Text
  degradedReason           String?               @db.VarChar(100)
  progressPercent          Int                   @default(0)
  progressLabel            String?               @db.VarChar(255)
  lastErrorCode            String?               @db.VarChar(100)
  lastErrorMessage         String?               @db.Text
  attempts                 Int                   @default(0)
  maxAttempts              Int                   @default(5)
  startedAt                DateTime?             @db.Timestamptz
  coreCompletedAt          DateTime?             @db.Timestamptz
  completedAt              DateTime?             @db.Timestamptz
  fullCompletedAt          DateTime?             @db.Timestamptz
  failedAt                 DateTime?             @db.Timestamptz
  googleAnalyticsSkippedAt DateTime?             @db.Timestamptz
  createdAt                DateTime              @default(now()) @db.Timestamptz
  updatedAt                DateTime              @updatedAt @db.Timestamptz

  store            Store    @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  currentJob       SyncJob? @relation("OnboardingCurrentJob", fields: [currentJobId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  productSyncJob   SyncJob? @relation("OnboardingProductSyncJob", fields: [productSyncJobId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  inventorySyncJob SyncJob? @relation("OnboardingInventorySyncJob", fields: [inventorySyncJobId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  ordersSyncJob    SyncJob? @relation("OnboardingOrdersSyncJob", fields: [ordersSyncJobId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([status], map: "store_onboarding_status_idx")
  @@index([status, updatedAt], map: "store_onboarding_stuck_idx")
  @@index([ordersSyncStatus], map: "store_onboarding_orders_status_idx")
  @@map("store_onboarding")
}

model JobEvent {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId      String        @db.Uuid
  jobId        String        @db.Uuid
  eventType    JobEventType
  fromStatus   JobStatus?
  toStatus     JobStatus?
  attemptNumber Int?
  message      String?       @db.Text
  metadataJson Json?         @db.JsonB
  actorType    JobEventActor @default(system)
  actorId      String?       @db.VarChar(255)
  createdAt    DateTime      @default(now()) @db.Timestamptz

  store Store   @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  job   SyncJob @relation(fields: [jobId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([jobId, createdAt], map: "job_events_job_id_created_at_idx")
  @@index([storeId, createdAt], map: "job_events_store_id_created_at_idx")
  @@index([eventType, createdAt], map: "job_events_event_type_created_at_idx")
  @@map("job_events")
}

model Plan {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String   @db.VarChar(100)
  slug              String   @unique @db.VarChar(50)
  monthlyPrice      Decimal  @db.Decimal(10, 2)
  annualPrice       Decimal  @db.Decimal(10, 2)
  maxProducts       Int
  maxOrders         Int
  maxTeamMembers    Int
  aiCreditsPerMonth Int
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @db.Timestamptz
  updatedAt         DateTime @updatedAt @db.Timestamptz

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId            String             @unique @db.Uuid
  planId             String             @db.Uuid
  status             SubscriptionStatus @default(trialing)
  currentPeriodStart DateTime           @db.Timestamptz
  currentPeriodEnd   DateTime           @db.Timestamptz
  trialEndsAt        DateTime?          @db.Timestamptz
  endedAt            DateTime?          @db.Timestamptz
  createdAt          DateTime           @default(now()) @db.Timestamptz
  updatedAt          DateTime           @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  plan  Plan  @relation(fields: [planId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([planId], map: "subscriptions_plan_id_idx")
  @@index([status], map: "subscriptions_status_idx")
  @@index([endedAt], map: "subscriptions_ended_at_idx")
  @@map("subscriptions")
}

model UsageRecord {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId   String      @db.Uuid
  metric    UsageMetric
  value     Int         @default(0)
  month     String      @db.VarChar(7)
  createdAt DateTime    @default(now()) @db.Timestamptz
  updatedAt DateTime    @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([storeId, metric, month], map: "usage_records_store_metric_month_unique")
  @@index([storeId, month], map: "usage_records_store_month_idx")
  @@map("usage_records")
}

model GoogleIntegration {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId               String    @unique @db.Uuid
  googleAccountId       String    @db.VarChar(100)
  email                 String    @db.VarChar(320)
  refreshToken          String
  accessToken           String
  expiresAt             DateTime  @db.Timestamptz
  connectedAt           DateTime  @default(now()) @db.Timestamptz
  lastSyncAt            DateTime? @db.Timestamptz
  analyticsPropertyId   String?   @db.VarChar(100)
  analyticsPropertyName String?   @db.VarChar(255)
  searchConsoleSiteUrl  String?   @db.VarChar(512)
  searchConsoleSiteName String?   @db.VarChar(255)
  searchConsoleLastSyncAt DateTime? @db.Timestamptz
  pageSpeedLastSyncAt   DateTime? @db.Timestamptz
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now()) @db.Timestamptz
  updatedAt             DateTime  @updatedAt @db.Timestamptz

