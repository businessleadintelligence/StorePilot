enum KnowledgeGraphNodeType {
  Store
  Product
  Variant
  Collection
  InventoryItem
  Vendor
  Location
  Order
  OrderItem
  Price
  Refund
  SeoRecord
  Media
  Experiment
  Evidence
  Recommendation
  OperationalIssue
  TrafficSource
  SearchQuery
  MarketingChannel
  BusinessDNA
  Decision
  Outcome
}

enum KnowledgeGraphEdgeType {
  BELONGS_TO
  CONTAINS
  USES
  CREATES
  AFFECTS
  DEPENDS_ON
  CAUSES
  SUPPORTS
  GENERATES
  OBSERVED_BY
  MEASURED_BY
  LEARNS_FROM
  PREDICTS
  RESULTED_IN
  CONNECTED_TO
  RELATED_TO
}

enum KnowledgeGraphNodeStatus {
  active
  archived
  expired
  pending
}

model KnowledgeGraphNode {
  id              String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId         String                   @db.Uuid
  nodeType        KnowledgeGraphNodeType
  canonicalKey    String                   @db.VarChar(150)
  displayName     String                   @db.VarChar(500)
  status          KnowledgeGraphNodeStatus @default(active)
  version         Int                      @default(1)
  confidence      Decimal                  @default(1) @db.Decimal(5, 4)
  metadata        Json                     @default("{}") @db.JsonB
  evidenceId      String?                  @db.Uuid
  createdAt       DateTime                 @default(now()) @db.Timestamptz
  updatedAt       DateTime                 @updatedAt @db.Timestamptz

  store              Store                      @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  evidence           Evidence?                  @relation(fields: [evidenceId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  edgesFrom          KnowledgeGraphEdge[]       @relation("GraphEdgeFrom")
  edgesTo            KnowledgeGraphEdge[]       @relation("GraphEdgeTo")
  relationshipsFrom  KnowledgeGraphRelationship[] @relation("GraphRelationshipFrom")
  relationshipsTo    KnowledgeGraphRelationship[] @relation("GraphRelationshipTo")
  searchIndexEntries KnowledgeGraphSearchIndex[]

  @@unique([storeId, nodeType, canonicalKey], map: "knowledge_graph_node_unique")
  @@index([storeId, nodeType], map: "knowledge_graph_node_store_type_idx")
  @@index([storeId, status], map: "knowledge_graph_node_store_status_idx")
  @@map("knowledge_graph_nodes")
}

model KnowledgeGraphEdge {
  id                 String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId            String                 @db.Uuid
  fromNodeId         String                 @db.Uuid
  toNodeId           String                 @db.Uuid
  relationship       KnowledgeGraphEdgeType
  confidence         Decimal                @default(1) @db.Decimal(5, 4)
  source             String                 @db.VarChar(100)
  evidenceId         String?                @db.Uuid
  evidenceVersion    Int?
  evidenceSource     String?                @db.VarChar(100)
  observationCount   Int                    @default(1)
  freshnessMinutes   Int?
  strength           Decimal?               @db.Decimal(5, 4)
  weight             Decimal?               @db.Decimal(8, 4)
  active             Boolean                @default(true)
  createdAt          DateTime               @default(now()) @db.Timestamptz
  expiresAt          DateTime?              @db.Timestamptz

  store    Store              @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  fromNode KnowledgeGraphNode @relation("GraphEdgeFrom", fields: [fromNodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  toNode   KnowledgeGraphNode @relation("GraphEdgeTo", fields: [toNodeId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  evidence Evidence?          @relation(fields: [evidenceId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([storeId, fromNodeId, toNodeId, relationship], map: "knowledge_graph_edge_unique")
  @@index([storeId, relationship], map: "knowledge_graph_edge_store_rel_idx")
  @@index([storeId, fromNodeId], map: "knowledge_graph_edge_from_idx")
  @@index([storeId, toNodeId], map: "knowledge_graph_edge_to_idx")
  @@index([storeId, evidenceId], map: "knowledge_graph_edge_evidence_idx")
  @@map("knowledge_graph_edges")
}

model KnowledgeGraphRelationship {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
