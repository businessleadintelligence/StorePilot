generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

enum SubscriptionPlan {
  starter
  growth
  agency
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
}

enum UserRole {
  owner
  member
}

enum ProductStatus {
  active
  archived
  draft
}

model Store {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shopifyDomain        String             @unique @db.VarChar(255)
  shopifyId            String             @unique @db.VarChar(100)
  accessToken          String
  storeName            String             @db.VarChar(255)
  currency             String             @default("USD") @db.VarChar(10)
  timezone             String             @default("UTC") @db.VarChar(100)
  subscriptionPlan     SubscriptionPlan   @default(starter)
  subscriptionStatus   SubscriptionStatus @default(trialing)
  trialEndsAt          DateTime?          @db.Timestamptz
  ga4PropertyId        String?            @db.VarChar(100)
  ga4RefreshToken      String?
  ga4ConnectedAt       DateTime?          @db.Timestamptz
  briefingTime         String             @default("08:00") @db.VarChar(5)
  briefingTimezone     String             @default("UTC") @db.VarChar(100)
  active               Boolean            @default(true)
  historicalImportDone Boolean            @default(false)
  lastOrdersSyncAt     DateTime?          @db.Timestamptz
  lastInventorySyncAt  DateTime?          @db.Timestamptz
  lastRefundsSyncAt    DateTime?          @db.Timestamptz
  lastProductsSyncAt   DateTime?          @db.Timestamptz
  lastGa4SyncAt        DateTime?          @db.Timestamptz
  createdAt            DateTime           @default(now()) @db.Timestamptz
  updatedAt            DateTime           @updatedAt @db.Timestamptz
  users                User[]
  products             Product[]
  webhookEvents        WebhookEvent[]

  @@index([active, subscriptionPlan])
  @@index([briefingTime])
  @@map("stores")
}

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId     String    @db.Uuid
  email       String    @db.VarChar(320)
  name        String?   @db.VarChar(255)
  role        UserRole  @default(owner)
  lastLoginAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([email, storeId], map: "users_email_store_idx")
  @@index([storeId], map: "users_store_id_idx")
  @@map("users")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Product {
  id                     String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId                String        @db.Uuid
  shopifyProductId       String        @db.VarChar(100)
  shopifyVariantId       String        @db.VarChar(100)
  shopifyInventoryItemId String?       @db.VarChar(100)
  title                  String        @db.VarChar(500)
  sku                    String?       @db.VarChar(255)
  status                 ProductStatus @default(active)
  price                  Decimal?      @db.Decimal(12, 2)
  inventoryQuantity      Int?
  inventoryTracked       Boolean       @default(true)
  createdAt              DateTime      @default(now()) @db.Timestamptz
  updatedAt              DateTime      @updatedAt @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([storeId, shopifyVariantId], map: "products_store_variant_unique")
  @@index([storeId], map: "products_store_id_idx")
  @@index([storeId, shopifyProductId], map: "products_store_product_idx")
  @@index([storeId, status], map: "products_status_idx")
  @@index([storeId, inventoryTracked], map: "products_inventory_tracked_idx")
  @@index([storeId, shopifyInventoryItemId], map: "products_inventory_item_idx")
  @@map("products")
}

model WebhookEvent {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  storeId               String   @db.Uuid
  shopifyWebhookId      String   @unique(map: "webhook_events_shopify_webhook_id_unique") @db.VarChar(255)
  shop                  String   @db.VarChar(255)
  topic                 String   @db.VarChar(100)
  processedSuccessfully Boolean  @default(true)
  processedAt           DateTime @default(now()) @db.Timestamptz
  createdAt             DateTime @default(now()) @db.Timestamptz

  store Store @relation(fields: [storeId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([storeId], map: "webhook_events_store_id_idx")
  @@map("webhook_events")
}
